	column TotalClass =
			
			CALCULATE(
			    COUNTROWS('opportunity_scoring'),
			    ALLEXCEPT('opportunity_scoring', 'opportunity_scoring'[data_split], 'opportunity_scoring'[Actual Won/Lost])
			)
		formatString: 0
		lineageTag: ee5d0828-df2b-43af-8ed8-ef9ae47e150b
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column PercInBin =
			
			VAR Denominator =
			    CALCULATE(
			        COUNTROWS('opportunity_scoring'),
			        REMOVEFILTERS('opportunity_scoring'[Probability Bins])
			    )
			RETURN
			DIVIDE(
			    COUNTROWS('opportunity_scoring'),
			    Denominator
			) * 100
		lineageTag: f862d16e-9c22-4ed9-a7dc-176bcc8633b9
		summarizeBy: none

		annotation SummarizationSetBy = User

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column TotalClassRows =
			
			CALCULATE(
			    COUNTROWS('opportunity_scoring'),
			    REMOVEFILTERS('opportunity_scoring'[Probability Bins]),
			    FILTER(
			        'opportunity_scoring',
			        'opportunity_scoring'[data_split] IN {"test", "validation"}
			    )
			)
		formatString: 0
		lineageTag: 8a6bf78a-4e7d-4fa7-9b25-42ec5db79478
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Actual Won/Lost' = IF('opportunity_scoring'[is_won] = 1, "Won", "Lost")
		lineageTag: 7938aab9-8e97-4375-8674-128d72ea2d9d
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Threshold = 0.5
		lineageTag: 31b33e3f-3170-4831-bb03-3f361020af15
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Predicted Probability Bin' =
			
			SWITCH (
			    TRUE(),
			    'opportunity_scoring'[prob_won] < 0.1,  "0.0-0.1",
			    'opportunity_scoring'[prob_won] < 0.2,  "0.1-0.2",
			    'opportunity_scoring'[prob_won] < 0.3,  "0.2-0.3",
			    'opportunity_scoring'[prob_won] < 0.4,  "0.3-0.4",
			    'opportunity_scoring'[prob_won] < 0.5,  "0.4-0.5",
			    'opportunity_scoring'[prob_won] < 0.6,  "0.5-0.6",
			    'opportunity_scoring'[prob_won] < 0.7,  "0.6-0.7",
			    'opportunity_scoring'[prob_won] < 0.8,  "0.7-0.8",
			    'opportunity_scoring'[prob_won] < 0.9,  "0.8-0.9",
			    'opportunity_scoring'[prob_won] <= 1,   "0.9-1.0",
			    BLANK()
			)
		lineageTag: a4740905-27b4-4597-b490-a75cf97ca744
		summarizeBy: none
		sortByColumn: 'Probability Bins'

		changedProperty = SortByColumn

		annotation SummarizationSetBy = Automatic

	column 'Predicted Won/Lost' =
			
			IF(
			    'opportunity_scoring'[prob_won] < 0.5,
			    "Predicted Lost (<0.5)",
			    "Predicted Won (>=0.5)"
			)
		lineageTag: 6f571cd8-1d93-4c93-9e05-1591ee1b8592
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

