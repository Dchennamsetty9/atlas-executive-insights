table opportunity_scoring
	lineageTag: bb54dbac-8ffb-45be-97ac-658a95e343be

	measure PercWonAboveThreshold =
			
			VAR threshold = 0.5
			RETURN
			DIVIDE(
			    CALCULATE(
			        COUNTROWS('opportunity_scoring'),
			        'opportunity_scoring'[is_won] = 1,
			        'opportunity_scoring'[Probability Bins] >= threshold,
			        'opportunity_scoring'[data_split] IN {"test", "validation"}
			    ),
			    CALCULATE(
			        COUNTROWS('opportunity_scoring'),
			        'opportunity_scoring'[is_won] = 1,
			        'opportunity_scoring'[data_split] IN {"test", "validation"}
			    )
			) * 100
		lineageTag: c098edc8-b576-4fe3-81c5-7bac6917f60c

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure PercLostAboveThreshold =
			
			VAR threshold = 0.5
			RETURN
			DIVIDE(
			    CALCULATE(
			        COUNTROWS('opportunity_scoring'),
			        'opportunity_scoring'[is_won] = 0,
			        'opportunity_scoring'[Probability Bins] >= threshold,
			        'opportunity_scoring'[data_split] IN {"test", "validation"}
			    ),
			    CALCULATE(
			        COUNTROWS('opportunity_scoring'),
			        'opportunity_scoring'[is_won] = 0,
			        'opportunity_scoring'[data_split] IN {"test", "validation"}
			    )
			) * 100
		lineageTag: c9f07bdf-900a-4a68-8a5e-8c061fc0f52b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure TP =
			-- True Positive (actual = Won, predicted = Won)
			CALCULATE(
			    DISTINCTCOUNT('opportunity_scoring'[salesforce_opportunity_line_item_id]),
			    'opportunity_scoring'[Actual Won/Lost] = "Won",
			    'opportunity_scoring'[Predicted Won/Lost] = "Predicted Won (>=0.5)"
			)
		formatString: 0
		lineageTag: 22711943-9f6d-401c-9889-c855ee7efc43

	measure TN =
			-- True Negative (actual = Lost, predicted = Lost)
			CALCULATE(
			    DISTINCTCOUNT('opportunity_scoring'[salesforce_opportunity_line_item_id]),
			    'opportunity_scoring'[Actual Won/Lost] = "Lost",
			    'opportunity_scoring'[Predicted Won/Lost] = "Predicted Lost (<0.5)"
			)
		formatString: 0
		lineageTag: d6f61f98-8866-4437-ab89-12b3ab2cd3cf

	measure FP =
			-- False Positive (actual = Lost, predicted = Won)
			CALCULATE(
			    DISTINCTCOUNT('opportunity_scoring'[salesforce_opportunity_line_item_id]),
			    'opportunity_scoring'[Actual Won/Lost] = "Lost",
			    'opportunity_scoring'[Predicted Won/Lost] = "Predicted Won (>=0.5)"
			)
		formatString: 0
		lineageTag: fe2e1432-6ac5-454e-906c-657b1dcc895c

	measure FN =
			-- False Negative (actual = Won, predicted = Lost)
			CALCULATE(
			    DISTINCTCOUNT('opportunity_scoring'[salesforce_opportunity_line_item_id]),
			    'opportunity_scoring'[Actual Won/Lost] = "Won",
			    'opportunity_scoring'[Predicted Won/Lost] = "Predicted Lost (<0.5)"
			)
		formatString: 0
		lineageTag: b606c6ad-7efe-4726-b194-167dc2f55f9a

	measure Accuracy =
			
			VAR TP = CALCULATE(
			    DISTINCTCOUNT('opportunity_scoring'[salesforce_opportunity_line_item_id]),
			    'opportunity_scoring'[Actual Won/Lost] = "Won",
			    'opportunity_scoring'[Predicted Won/Lost] = "Predicted Won (>=0.5)"
			)
			VAR TN = CALCULATE(
			    DISTINCTCOUNT('opportunity_scoring'[salesforce_opportunity_line_item_id]),
			    'opportunity_scoring'[Actual Won/Lost] = "Lost",
			    'opportunity_scoring'[Predicted Won/Lost] = "Predicted Lost (<0.5)"
			)
			VAR TOTAL = CALCULATE(DISTINCTCOUNT('opportunity_scoring'[salesforce_opportunity_line_item_id]))
			RETURN
			DIVIDE(TP + TN, TOTAL)
		lineageTag: 61ff6630-41c6-4a91-97bf-3113b0c5c737

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Precision =
			
			VAR TP = CALCULATE(
			    DISTINCTCOUNT('opportunity_scoring'[salesforce_opportunity_line_item_id]),
			    'opportunity_scoring'[Actual Won/Lost] = "Won",
			    'opportunity_scoring'[Predicted Won/Lost] = "Predicted Won (>=0.5)"
			)
			VAR FP = CALCULATE(
			    DISTINCTCOUNT('opportunity_scoring'[salesforce_opportunity_line_item_id]),
			    'opportunity_scoring'[Actual Won/Lost] = "Lost",
			    'opportunity_scoring'[Predicted Won/Lost] = "Predicted Won (>=0.5)"
			)
			RETURN
			DIVIDE(TP, TP + FP)
		lineageTag: f1570afc-e195-4754-9de7-d0ec51fcc56f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Recall = DIVIDE([TP_only], [TP_only] + [FN_only])
		lineageTag: 17c5ca53-2182-48a3-8a0f-56e27efcd243

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure FN_only = ```
			
			CALCULATE(
			    DISTINCTCOUNT('opportunity_scoring'[salesforce_opportunity_line_item_id]), 
			    FILTER(
			        'opportunity_scoring', 
			        'opportunity_scoring'[Actual Won/Lost] = "Won" 
			        && 'opportunity_scoring'[Predicted Won/Lost] = "Predicted Lost (<0.5)"
			    )
			)
			```
		formatString: 0
		lineageTag: d0aec525-03b4-46fe-a6b9-5b0184d70b3a

	measure TP_only =
			
			CALCULATE(
			    DISTINCTCOUNT('opportunity_scoring'[salesforce_opportunity_line_item_id]),
			    FILTER(
			        'opportunity_scoring',
			        'opportunity_scoring'[Actual Won/Lost] = "Won"
			            && 'opportunity_scoring'[Predicted Won/Lost] = "Predicted Won (>=0.5)"
			    )
			)
		formatString: 0
		lineageTag: ea434281-89ef-41ba-8912-0b2f2c8e5e70

