		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isDecimal":true}

	column 'Most Likely Amount' =
			
			VAR SwitchVal =
			    SELECTEDVALUE('SelfServeSwitch'[Value], 0)
			RETURN
			    IF(
			        SwitchVal = 1,
			        forecast_prophet[Most Likely Amount (Self Serve and Miradore Adjusted)],
			        forecast_prophet[most_likely]
			    )
		lineageTag: 21f76e00-ed7c-4744-8489-86c6db827130
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column ISOWeek =
			
			WEEKNUM(
			    'forecast_prophet'[ds] - WEEKDAY('forecast_prophet'[ds], 2) + 4,
			    2
			)
		formatString: 0
		lineageTag: 1a2480e7-155d-4d2c-b6ed-4f0aaa11aefc
