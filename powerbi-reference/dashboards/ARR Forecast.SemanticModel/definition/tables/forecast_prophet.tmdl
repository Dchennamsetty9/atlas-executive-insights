	column Today? = IF('forecast_prophet'[ds] = (TODAY() - 1), "Yes", IF('forecast_prophet'[ds] < TODAY(), "Past Date", "No"))
		lineageTag: 1c590102-89c4-44ec-8da3-14f7e90c5b63
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'ARR YTD' =
			
			VAR LastClosedWeekEnd = TODAY() - WEEKDAY(TODAY(), 2)   // previous Sunday
			RETURN
			    CALCULATE(
			        SUM('forecast_prophet'[actuals]),
			        FILTER(
			            ALL('forecast_prophet'[ds]),
			            'forecast_prophet'[ds] <= LastClosedWeekEnd
			        )
			    )
		formatString: #,0
		lineageTag: 90ce6101-5c7e-438e-94fe-87de7613d231
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isDecimal":true}

	column Week = ```
			
			"Week" & 
			    1 + 
			    INT(
			        DIVIDE(
			            DATEDIFF(
			                CALCULATE(MIN('forecast_prophet'[ds]), ALL('forecast_prophet')),
			                'forecast_prophet'[ds],
			                DAY
			            ),
			            7,
			            0
			        )
			    )
			```
		lineageTag: 8576ea8b-7531-46e2-9181-a9772f55bfc3
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column MinDateThisYear = ```
			
			    CALCULATE(
			        MIN('forecast_prophet'[ds]), 
			        FILTER(
			            'forecast_prophet', 
			            YEAR('forecast_prophet'[ds]) = YEAR(EARLIER('forecast_prophet'[ds]))
			        )
			    )
			```
		formatString: General Date
		lineageTag: 4c0f63df-b116-45c3-8803-ae8a19238fc6
		summarizeBy: none

		variation Variation
			isDefault
			relationship: 73f251aa-04e8-4e1c-b6b4-bb15d0e3f45d
			defaultHierarchy: LocalDateTable_41308ac8-7301-4af5-9fc6-e826a5016e5e.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

	column RelWeekNumber = ```
			
			    "Week" &
			    1 +
			    INT(
			        DIVIDE(
			            DATEDIFF(
			                [MinDateThisYear],
			                'forecast_prophet'[ds],
			                DAY
			            ), 
			            7,
			            0
			        )
			    )
			```
		lineageTag: 97f2d67e-6b8b-4395-9378-a4bc6dc25356
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'adjusted most_likely' =
			
			IF(
			    'forecast_prophet'[Today?] = "Past Date",
