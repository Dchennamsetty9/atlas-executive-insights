	column Product_group =
			
			SWITCH(
			    TRUE(),
			    [product] = "Core Collab", "UCC",
			    [product] = "UCaaS", "UCC",
			    [product] // fallback: original value
			)
		lineageTag: 8c2e07f2-c900-42c1-abc7-483c9326622f
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column xkey = CONCATENATE(forecast_prophet[ds], CONCATENATE(forecast_prophet[product], CONCATENATE(forecast_prophet[sales_market], forecast_prophet[pe_account_flag])))
		lineageTag: eee4c30e-3c82-42cf-bbca-447409aa3833
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column WeekStart =
			
			VAR inputDate = [ds]
			VAR weekdayNum = WEEKDAY(inputDate, 2)
			RETURN inputDate - (weekdayNum - 1)
		formatString: General Date
		lineageTag: f9b057fc-4144-490b-ac54-386bf4fedf90
		summarizeBy: none

		variation Variation
			isDefault
			relationship: 887fb352-f4e9-4fa5-9bbb-845f8a0537d2
			defaultHierarchy: LocalDateTable_484ed2ef-1e99-41bc-af99-5c53e71a1289.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

	column WeekNumber =
			
			VAR ThisYear = YEAR([WeekStart])
			VAR MinMonday =
			    CALCULATE(
			        MIN('forecast_prophet'[WeekStart]),
			        ALL('forecast_prophet'),
			        YEAR('forecast_prophet'[WeekStart]) = ThisYear
			    )
			RETURN
			"Week " & (1 + DIVIDE(DATEDIFF(MinMonday, [WeekStart], DAY), 7, 0))
		lineageTag: 59770e56-19c2-4562-89fd-7c3ee9acf767
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column mc_actuals =
			
			VAR y = VALUE([year])
			VAR m = VALUE([month])
			RETURN
			    IF(
			        y IN {2024, 2025} || (y = 2026 && m = 1),
			        [marketing_generated_pipeline],
			        [Actuals]
			    )
		formatString: #,0
		lineageTag: 9108942e-6733-41ce-b3d6-bc6e1e5159f9
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isDecimal":true}

	column SelfServeAdjustment =
			
			VAR ThisYear    = forecast_prophet[year]
			VAR ThisQuarter = QUARTER(forecast_prophet[ds])
			VAR ThisProduct = forecast_prophet[product]
			VAR ThisMarket  = forecast_prophet[sales_market]
			VAR ThisFlag    = forecast_prophet[pe_account_flag]
			VAR MaxDateInQuarter =
			    CALCULATE(
			        MAX(forecast_prophet[ds]),
			        FILTER(
			            forecast_prophet,
			            forecast_prophet[year] = ThisYear &&
			            QUARTER(forecast_prophet[ds]) = ThisQuarter &&
			            forecast_prophet[product] = ThisProduct &&
			            forecast_prophet[sales_market] = ThisMarket &&
			            forecast_prophet[pe_account_flag] = ThisFlag
			        )
			    )
			RETURN
			    IF(
			        forecast_prophet[ds] = MaxDateInQuarter &&
			        forecast_prophet[product] = "UCC" &&
			        forecast_prophet[sales_market] = "NA" &&
			        forecast_prophet[pe_account_flag] = "false",
			        200000,
			        0
			    )
		formatString: 0
		lineageTag: 6518a03b-823a-408a-a24d-c1a97210df8e
		summarizeBy: sum

