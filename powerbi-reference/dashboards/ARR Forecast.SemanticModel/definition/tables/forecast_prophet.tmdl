	measure Actuals_AllYears =
			
			CALCULATE(
			    SUM('forecast_prophet'[ARR YTD]),
			    REMOVEFILTERS('forecast_prophet'[year])
			)
		formatString: #,0
		lineageTag: 12ed7b2c-2c8f-45f1-8953-a991fe6e524c

		annotation PBI_FormatHint = {"isDecimal":true}

	measure Forecast_AllYears =
			
			VAR y = SELECTEDVALUE('forecast_prophet'[year])
			RETURN
			IF(
			    y >= 2024 && y <= 2026,                     -- show forecast only for years you have
			    CALCULATE(
			        SUM('forecast_prophet'[most_likely]),
			        REMOVEFILTERS('forecast_prophet'[ISOYear])
			    ),
			    BLANK()
			)
		lineageTag: 737a0047-c144-4fd0-8478-ece24b92834b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Series Value' =
			
			VAR s          = SELECTEDVALUE('Legend Series'[Series])
			VAR IsForecast = LEFT(s, 8) = "Forecast"
			VAR YearNum    = VALUE(RIGHT(s, 4))
			
			// Week number coming from the X-axis (works whether the axis is from forecast_prophet or a Date table)
			VAR WeekNumAxis =
			    COALESCE(
			        SELECTEDVALUE('forecast_prophet'[ISOWeek]),
			        SELECTEDVALUE('Dates Table'[Weekday])
			    )
			
			// Build current point’s Year+Week key
			VAR CurrentWeekKey = YearNum * 100 + WeekNumAxis
			
			// End of last finished week (Mon-start ISO weeks -> previous Sunday)
			VAR LastClosedDate = TODAY() - WEEKDAY(TODAY(), 2)
			
			// Cutoff week key for THIS ISO year (max week whose date is on/before last closed date)
			VAR CutoffWeekKey =
			    CALCULATE(
			        MAX('forecast_prophet'[WeekYearKey]),
			        FILTER(
			            ALL('forecast_prophet'),
			            'forecast_prophet'[ISOYear] = YearNum &&
			            'forecast_prophet'[ds] <= LastClosedDate
			            // If you only want weeks that have actuals loaded, uncomment the next line:
			            // && NOT ISBLANK('forecast_prophet'[actuals])
			        )
			    )
			
			RETURN
			IF(
			    IsForecast,
			    CALCULATE(
			        SUM('forecast_prophet'[most_likely]),
			        // make the chart immune to Year/Date slicers on the fact
			        REMOVEFILTERS('forecast_prophet'[ISOYear], 'forecast_prophet'[year], 'forecast_prophet'[ds]),
			        // align to ISOYear (not calendar year)
			        'forecast_prophet'[ISOYear] = YearNum
			    ),
			    VAR val =
			        CALCULATE(
			            SUM('forecast_prophet'[actuals]),
			            REMOVEFILTERS('forecast_prophet'[ISOYear], 'forecast_prophet'[year], 'forecast_prophet'[ds]),
			            'forecast_prophet'[ISOYear] = YearNum
			        )
			    VAR pastCutoff =
			        NOT ISBLANK(CutoffWeekKey) &&
			        NOT ISBLANK(WeekNumAxis) &&
			        CurrentWeekKey > CutoffWeekKey
			    RETURN IF(pastCutoff || val = 0, BLANK(), val)
			)
		lineageTag: c71b6169-4628-48cd-acd8-61d0b6d3c397

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Actuals Closed Week Start (Mon)' =
			
			VAR ThisWeekStart = TODAY() - WEEKDAY(TODAY(), 2) + 1   // Monday of current week
			VAR LagWeeks = 1
			RETURN ThisWeekStart - 7 * LagWeeks                     // Monday of last closed week
		formatString: Short Date
		lineageTag: 51dfc5dd-6ca4-45a2-b681-2129d722175c

	measure 'Actuals Closed Week No' =
			
			VAR StartDate = [Actuals Closed Week Start (Mon)]
			RETURN WEEKNUM(StartDate, 21)   // ISO week numbering
		formatString: 0
		lineageTag: 8642c60e-745b-41ba-b7fa-efb0412873a6

	measure 'Actuals As Of (Label)' =
			
			VAR StartDate = [Actuals Closed Week Start (Mon)]
			VAR EndDate   = [Actuals Closed Week End (Sun)]
			VAR WeekNo    = [Actuals Closed Week No]
			RETURN
			    "Week " & WeekNo & " " &
			    FORMAT(StartDate, "mmm d") & " - " & FORMAT(EndDate, "mmm d")
		lineageTag: c602b068-bff0-4db9-9e12-fb64f5ddab47

	measure 'Actuals As Of Week Key' =
			
			VAR CurrentISOWeekKey =
			    YEAR(TODAY()) * 100 + WEEKNUM(TODAY(), 21)   // ISO week num (Mon start)
			VAR WeeksWithTotals =
			    SUMMARIZE(
			        FILTER(
			            ALL('forecast_prophet'),
			            'forecast_prophet'[WeekYearKey] < CurrentISOWeekKey
			        ),
			        'forecast_prophet'[ISOYear],
			        'forecast_prophet'[ISOWeek],
			        'forecast_prophet'[WeekYearKey],
			        "ActualsWeekTotal", SUM('forecast_prophet'[actuals])
			    )
			RETURN
			    MAXX(
			        FILTER(WeeksWithTotals, [ActualsWeekTotal] > 0),
			        'forecast_prophet'[WeekYearKey]
			    )
		formatString: 0
		lineageTag: c542fa87-98eb-40da-b085-061fbb504f23

	measure 'Actuals Closed Week End (Sun)' =
			
			VAR StartDate = [Actuals Closed Week Start (Mon)]
			RETURN StartDate + 6
		formatString: General Date
		lineageTag: 1b862a1f-15ec-445b-a2a6-ff617b7d692b

	measure 'Tooltip Week Label' =
			
			VAR axisDate =
			    COALESCE(
			        SELECTEDVALUE('forecast_prophet'[ds]),
			        SELECTEDVALUE('Dates Table'[Date]),
			        MAX('forecast_prophet'[ds])       // fallback if context isn’t single-valued
			    )
			VAR weekStart = axisDate - WEEKDAY(axisDate, 2) + 1    // Monday
			VAR weekEnd   = weekStart + 6                          // Sunday
			// ISO week: take Thursday of the same week and use Monday-start week numbering
			VAR thursday  = weekStart + 3
			VAR isoWeek   = WEEKNUM(thursday, 2)                   // use 2 (Mon-start). DAX doesn’t support 21.
			RETURN
			IF(
			    NOT ISBLANK(axisDate),
			    "Week " & isoWeek & " " &
			    FORMAT(weekStart, "mmm d") & " - " & FORMAT(weekEnd, "mmm d")
			)
		lineageTag: 5567489a-3985-489d-99c0-cfe881de6ac3

