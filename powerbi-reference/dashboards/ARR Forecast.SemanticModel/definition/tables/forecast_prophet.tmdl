	column ISOYear =
			
			YEAR(
			    'forecast_prophet'[ds] - WEEKDAY('forecast_prophet'[ds], 2) + 4
			)
		formatString: 0
		lineageTag: 9369b890-61aa-43b2-9d57-e1d600bfcf8d
