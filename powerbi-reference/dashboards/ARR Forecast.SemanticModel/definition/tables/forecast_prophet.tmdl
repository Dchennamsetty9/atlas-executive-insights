	column WeekYearKey =
			
			YEAR('forecast_prophet'[ds] - WEEKDAY('forecast_prophet'[ds], 2) + 4) * 100
			+ WEEKNUM('forecast_prophet'[ds] - WEEKDAY('forecast_prophet'[ds], 2) + 4, 2)
		formatString: 0
		lineageTag: bccc0fcb-7fac-415a-a985-96b2666170bc
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column ISOWeekLabel =
			
			VAR d = 'forecast_prophet'[ds]
			VAR isoYr = YEAR(d + 3)
			VAR isoWk = WEEKNUM(d + 3, 2)
			VAR firstWk =
			CALCULATE(
			MINX(ALL('forecast_prophet'), WEEKNUM('forecast_prophet'[ds] + 3, 2)),
			FILTER(ALL('forecast_prophet'), YEAR('forecast_prophet'[ds] + 3) = isoYr)
			)
			VAR normWk = isoWk - (firstWk)
			RETURN "Week " & FORMAT(normWk, "00")
		lineageTag: 20f92bf2-cc9b-4b57-bd2e-1e5df2a79187
		summarizeBy: none

