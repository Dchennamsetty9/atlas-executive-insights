	column quarter =
			
			QUARTER(forecast_prophet[ds])
		formatString: 0
		lineageTag: 3672c402-cecf-477d-b8d0-5a15283b1f38
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column IsQuarterEnd =
			
			VAR ThisYear    = forecast_prophet[year]
			VAR ThisQuarter = QUARTER(forecast_prophet[ds])
			VAR ThisMarket  = forecast_prophet[sales_market]
			VAR ThisProduct = forecast_prophet[product]
			VAR ThisFlag    = forecast_prophet[pe_account_flag]
			
			VAR MaxDateInQuarter =
			    CALCULATE(
			        MAX(forecast_prophet[ds]),
			        FILTER(
			            forecast_prophet,
			            forecast_prophet[year] = ThisYear &&
			            QUARTER(forecast_prophet[ds]) = ThisQuarter &&
			            forecast_prophet[product] = ThisProduct &&
			            forecast_prophet[sales_market] = ThisMarket &&
			            forecast_prophet[pe_account_flag] = ThisFlag
			        )
			    )
			RETURN
			    IF(forecast_prophet[ds] = MaxDateInQuarter, 1, 0)
		formatString: 0
		lineageTag: b080bec5-c86d-41bf-83e7-5bbd46c83b62
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Most Likely Amount (Self Serve and Miradore Adjusted)' = ```
			
			    forecast_prophet[most_likely] + forecast_prophet[SelfServeAdjustment] + forecast_prophet[marketing_influenced_pipeline]
			```
		formatString: #,0
