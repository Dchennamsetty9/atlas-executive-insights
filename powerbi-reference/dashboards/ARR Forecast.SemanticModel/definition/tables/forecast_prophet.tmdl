table forecast_prophet
	lineageTag: a83db36d-aabc-4e3a-a8d6-80cbc1c1419a

	measure 'Running Totals Actuals' =
			
			VAR LastClosedWeekEnd =
			    TODAY() - WEEKDAY(TODAY(), 2)   -- previous Sunday
			
			VAR CurrentAxisDate =
			    MAX('forecast_prophet'[ds])
			
			RETURN
			IF(
			    CurrentAxisDate > LastClosedWeekEnd,
			    BLANK(),
			    CALCULATE(
			        [2025actuals$],
			        DATESYTD('forecast_prophet'[ds])
			    )
			)
		formatString: #,0
		lineageTag: 9e9a2d7b-2fe2-44ee-bbf5-49ff7ff7babf

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 2025actuals$ = CALCULATE(SUM('forecast_prophet'[Actuals]))
		lineageTag: eb05ea93-73ec-4171-b650-f11e664dac38

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 2025bestcase$ = CALCULATE(SUM('forecast_prophet'[best_case]))
