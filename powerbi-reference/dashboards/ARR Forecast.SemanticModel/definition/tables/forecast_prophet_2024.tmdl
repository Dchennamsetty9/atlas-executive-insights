	column 'Running Total Actuals' =
			
			IF(
			    YEAR('forecast_prophet_2024'[ds]) = 2024,
			    CALCULATE(
			        SUM('forecast_prophet_2024'[Actuals]),
			        FILTER(
			            'forecast_prophet_2024',
			            'forecast_prophet_2024'[ds] <= EARLIER('forecast_prophet_2024'[ds]) &&
			            YEAR('forecast_prophet_2024'[ds]) = 2024
			        )
			    ),
			    BLANK()
			)
		lineageTag: 43c76d2b-0d0d-4f23-b55e-7752b67ae1cd
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Running Total Best Case' =
			CALCULATE(
			    SUM('forecast_prophet_2024'[best_case]),
			    FILTER(
			        'forecast_prophet_2024',
			        'forecast_prophet_2024'[ds] <= EARLIER('forecast_prophet_2024'[ds])
			    )
			)
		lineageTag: 6f7981e1-d663-4266-9b8e-2c50bf027408
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Running Total Most Likely' =
			CALCULATE(
			    SUM('forecast_prophet_2024'[most_likely]),
			    FILTER(
			        'forecast_prophet_2024',
			        'forecast_prophet_2024'[ds] <= EARLIER('forecast_prophet_2024'[ds])
			    )
			)
		lineageTag: 902e3494-7669-47b7-9569-726b9c193c02
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Running Total Worst Case' =
			CALCULATE(
			    SUM('forecast_prophet_2024'[worst_case]),
			    FILTER(
			        'forecast_prophet_2024',
			        'forecast_prophet_2024'[ds] <= EARLIER('forecast_prophet_2024'[ds])
			    )
			)
		lineageTag: a3153ed4-11ea-4f5e-b7f0-b030d938c779
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column Product_group =
			
			SWITCH(
			    TRUE(),
			    [product] = "Core Collab", "UCC",
			    [product] = "UCaaS", "UCC",
			    [product] // fallback: original value
			)
		lineageTag: bbd6f211-d156-4eb0-97cc-251541f79075
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Difference = forecast_prophet_2024[most_likely] - forecast_prophet_2024[actuals]
