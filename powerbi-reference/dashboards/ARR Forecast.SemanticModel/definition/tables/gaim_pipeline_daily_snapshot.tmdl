	column sales_market = ```
			
			IF(
			    ISBLANK(gaim_pipeline_daily_snapshot[market]) || gaim_pipeline_daily_snapshot[market] = "", 
			    "Unknown",
			    IF(
			        gaim_pipeline_daily_snapshot[market] = "INDIA", "APAC",
			        IF(
			            gaim_pipeline_daily_snapshot[market] = "AUS/ROW", "APAC",
			            gaim_pipeline_daily_snapshot[market]
			        )
			    )
			)
			```
