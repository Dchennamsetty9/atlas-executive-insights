# Databricks Configuration (recommended - same as Performance Hub)
DATABRICKS_SERVER_HOSTNAME=goto-data-dock.cloud.databricks.com
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/c24ee33594e13e93
DATABRICKS_ACCESS_TOKEN=your-databricks-token-here
DATABRICKS_CATALOG=datagroup_mdl
DATABRICKS_SCHEMA=mdl_sales_analytics

# Alternative: SQL Server (if not using Databricks)
DB_SERVER=your-database-server.database.windows.net
DB_NAME=your_database_name
DB_USER=your_username
DB_PASSWORD=your_password
DB_DRIVER=ODBC Driver 18 for SQL Server

# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Application Settings
ENVIRONMENT=development
DEBUG=True
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Forecasting Settings
FORECAST_DEFAULT_PERIODS=90
FORECAST_CONFIDENCE_INTERVAL=0.95
