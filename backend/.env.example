# ── Databricks ────────────────────────────────────────────────────────────────
# DATABRICKS_TOKEN is the canonical name; DATABRICKS_ACCESS_TOKEN is also accepted.
DATABRICKS_TOKEN=dapi_xxxxx
DATABRICKS_HOST=goto-data-dock.cloud.databricks.com
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/c24ee33594e13e93
DATABRICKS_CATALOG=datagroup_mdl
DATABRICKS_SCHEMA=mdl_sales_analytics

# ── Databricks Genie ──────────────────────────────────────────────────────────
GENIE_SPACE_ID=01f10b2015dc1186928a78ee0bb4869f

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
# AZURE_OPENAI_KEY and AZURE_OPENAI_API_KEY are both accepted.
AZURE_OPENAI_KEY=xxxxx
AZURE_OPENAI_ENDPOINT=https://xxxxx.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ── App Config ────────────────────────────────────────────────────────────────
DATA_REFRESH_INTERVAL_MINUTES=15
CACHE_ENABLED=true
ENVIRONMENT=development
DEBUG=True
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
