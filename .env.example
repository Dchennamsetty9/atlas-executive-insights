# =============================================================================
# Atlas Executive Insights — Environment Variables
# Copy this file to .env and fill in values for local development.
# NEVER commit .env to version control.
# On Databricks Apps, these are set via the Apps configuration UI.
# =============================================================================

# ── Databricks ────────────────────────────────────────────────────────────────
# Required for local development. On Databricks Apps these are injected automatically.
DATABRICKS_SERVER_HOSTNAME=goto-data-dock.cloud.databricks.com
DATABRICKS_TOKEN=
# HTTP path for the SQL Warehouse
# DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/c24ee33594e13e93

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
PORT=8000

# Set to true to run entirely on built-in demo data (no Databricks connection required)
DEMO_MODE=false

# ── Gold Layer (pre-computed Delta tables) ────────────────────────────────────
# Catalog and schema where the 8 Atlas gold tables live.
# Created by schemas/atlas_gold_layer.sql. Default values shown.
ATLAS_CATALOG=datagroup_mdl
ATLAS_SCHEMA=atlas

# ── User Preferences & Actions (Delta tables in MDL schema) ──────────────────
USER_PREFS_CATALOG=datagroup_mdl
USER_PREFS_SCHEMA=mdl_sales_analytics
USER_PREFS_TABLE=atlas_user_preferences
ACTIONS_TABLE=atlas_executive_actions
NOTIFICATIONS_TABLE=atlas_notifications

# ── Alert Thresholds ──────────────────────────────────────────────────────────
# Fraction of paced target below which an alert is triggered.
ALERT_THRESHOLD_AT_RISK=0.90
ALERT_THRESHOLD_CRITICAL=0.75

# ── AWS SES (preferred email transport) ───────────────────────────────────────
# When AWS_SES_REGION is set, SES is used instead of SMTP.
# Credentials are resolved from the environment (instance profile, ~/.aws/credentials, or below).
AWS_SES_REGION=us-east-1
SES_FROM_EMAIL=atlas-alerts@goto.com
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── SMTP (fallback email transport — used only when AWS_SES_REGION is empty) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=atlas-alerts@goto.com
SMTP_TLS=true

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#atlas-alerts

# ── Notification email recipient (default for alert dispatches) ───────────────
NOTIFICATION_EMAIL=dchennamsetty@goto.com

# ── Genie Space ───────────────────────────────────────────────────────────────
# Databricks Genie space ID for the AI chat panel.
GENIE_SPACE_ID=01f10b2015dc1186928a78ee0bb4869f
